components:
  schemas:
    ActionEnum:
      enum:
      - create
      - update
      - delete
      - login
      - logout
      - approve
      - reject
      type: string
      description: |-
        * `create` - Erstellt
        * `update` - Aktualisiert
        * `delete` - Gelöscht
        * `login` - Anmeldung
        * `logout` - Abmeldung
        * `approve` - Genehmigt
        * `reject` - Abgelehnt
    AdminUserCompact:
      type: object
      description: Compact user representation for admin panel.
      properties:
        id:
          type: integer
          readOnly: true
        first_name:
          type: string
          readOnly: true
        last_name:
          type: string
          readOnly: true
      required:
      - first_name
      - id
      - last_name
    AuditLog:
      type: object
      description: Serializer for audit log entries.
      properties:
        id:
          type: integer
          readOnly: true
        user:
          allOf:
          - $ref: '#/components/schemas/AdminUserCompact'
          readOnly: true
        action:
          allOf:
          - $ref: '#/components/schemas/ActionEnum'
          readOnly: true
          title: Aktion
        model_name:
          type: string
          readOnly: true
          title: Modell
        object_id:
          type: string
          readOnly: true
          title: Objekt-ID
        changes:
          readOnly: true
          title: Änderungen
        ip_address:
          type: string
          readOnly: true
          nullable: true
          title: IP-Adresse
        created_at:
          type: string
          format: date-time
          readOnly: true
          title: Erstellt am
      required:
      - action
      - changes
      - created_at
      - id
      - ip_address
      - model_name
      - object_id
      - user
    CategoryTypeEnum:
      enum:
      - income
      - expense
      type: string
      description: |-
        * `income` - Einnahme
        * `expense` - Ausgabe
    GroupCreate:
      type: object
      description: Serializer for creating/updating groups.
      properties:
        id:
          type: integer
          readOnly: true
        school_year:
          type: integer
          title: Schuljahr
        name:
          type: string
          maxLength: 255
        description:
          type: string
          title: Beschreibung
        leader:
          type: integer
          nullable: true
          title: Gruppenleitung
        is_active:
          type: boolean
          title: Aktiv
      required:
      - id
      - name
      - school_year
    GroupCreateRequest:
      type: object
      description: Serializer for creating/updating groups.
      properties:
        school_year:
          type: integer
          title: Schuljahr
        name:
          type: string
          minLength: 1
          maxLength: 255
        description:
          type: string
          title: Beschreibung
        leader:
          type: integer
          nullable: true
          title: Gruppenleitung
        is_active:
          type: boolean
          title: Aktiv
      required:
      - name
      - school_year
    GroupDetail:
      type: object
      description: Serializer for group detail view (includes members and students).
      properties:
        id:
          type: integer
          readOnly: true
        location:
          type: integer
          title: Standort
        location_name:
          type: string
          readOnly: true
        school_year:
          type: integer
          title: Schuljahr
        school_year_name:
          type: string
          readOnly: true
        name:
          type: string
          maxLength: 255
        description:
          type: string
          title: Beschreibung
        leader:
          allOf:
          - $ref: '#/components/schemas/UserCompact'
          readOnly: true
        members:
          type: array
          items:
            $ref: '#/components/schemas/GroupMember'
          readOnly: true
        students:
          type: array
          items:
            $ref: '#/components/schemas/StudentList'
          readOnly: true
        balance:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          readOnly: true
          title: Kontostand
          description: Aktueller Kontostand der Gruppenkasse in EUR
        currency:
          type: string
          title: Waehrung
          maxLength: 3
        is_active:
          type: boolean
          title: Aktiv
        created_at:
          type: string
          format: date-time
          readOnly: true
          title: Erstellt am
        updated_at:
          type: string
          format: date-time
          readOnly: true
          title: Aktualisiert am
      required:
      - balance
      - created_at
      - id
      - leader
      - location
      - location_name
      - members
      - name
      - school_year
      - school_year_name
      - students
      - updated_at
    GroupList:
      type: object
      description: Serializer for listing groups (compact).
      properties:
        id:
          type: integer
          readOnly: true
        location:
          type: integer
          title: Standort
        location_name:
          type: string
          readOnly: true
        school_year:
          type: integer
          title: Schuljahr
        school_year_name:
          type: string
          readOnly: true
        name:
          type: string
          maxLength: 255
        description:
          type: string
          title: Beschreibung
        leader:
          allOf:
          - $ref: '#/components/schemas/UserCompact'
          readOnly: true
        member_count:
          type: integer
          readOnly: true
        student_count:
          type: integer
          readOnly: true
        balance:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          readOnly: true
          title: Kontostand
          description: Aktueller Kontostand der Gruppenkasse in EUR
        currency:
          type: string
          title: Waehrung
          maxLength: 3
        is_active:
          type: boolean
          title: Aktiv
        created_at:
          type: string
          format: date-time
          readOnly: true
          title: Erstellt am
      required:
      - balance
      - created_at
      - id
      - leader
      - location
      - location_name
      - member_count
      - name
      - school_year
      - school_year_name
      - student_count
    GroupListRequest:
      type: object
      description: Serializer for listing groups (compact).
      properties:
        location:
          type: integer
          title: Standort
        school_year:
          type: integer
          title: Schuljahr
        name:
          type: string
          minLength: 1
          maxLength: 255
        description:
          type: string
          title: Beschreibung
        currency:
          type: string
          minLength: 1
          title: Waehrung
          maxLength: 3
        is_active:
          type: boolean
          title: Aktiv
      required:
      - location
      - name
      - school_year
    GroupMember:
      type: object
