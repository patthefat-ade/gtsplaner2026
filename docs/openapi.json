openapi: 3.0.3
info:
  title: Kassenbuch App v2 API
  version: 2.0.0
  description: REST API für die Kassenbuch App v2 – Verwaltung von Klassenkassen für
    Freizeitpädagoginnen. Django + Next.js Headless Architecture.
paths:
  /api/health/:
    get:
      operationId: api_health_retrieve
      description: Health check endpoint to verify the API is running.
      tags:
      - api
      security:
      - jwtAuth: []
      - cookieAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/v1/admin/audit-logs/:
    get:
      operationId: admin_audit_logs_list
      description: Read-only access to audit log entries (Admin/SuperAdmin only).
      summary: Audit-Log auflisten
      parameters:
      - in: query
        name: action
        schema:
          type: string
      - in: query
        name: end_date
        schema:
          type: string
          format: date
      - in: query
        name: model_name
        schema:
          type: string
      - name: ordering
        required: false
        in: query
        description: Feld, das zum Sortieren der Ergebnisse verwendet werden soll.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: Eine Seitenzahl in der paginierten Ergebnismenge.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: Ein Suchbegriff.
        schema:
          type: string
      - in: query
        name: start_date
        schema:
          type: string
          format: date
      - in: query
        name: user_id
        schema:
          type: number
      tags:
      - Admin
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAuditLogList'
          description: ''
  /api/v1/admin/audit-logs/{id}/:
    get:
      operationId: admin_audit_logs_retrieve
      description: Read-only access to audit log entries (Admin/SuperAdmin only).
      summary: Audit-Log-Eintrag abrufen
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: Ein eindeutiger Ganzzahl-Wert, der Audit-Log identifiziert.
        required: true
      tags:
      - Admin
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AuditLog'
          description: ''
  /api/v1/admin/settings/:
    get:
      operationId: admin_settings_list
      description: CRUD for system settings (SuperAdmin only for write, Admin for
        read).
      summary: Systemeinstellungen auflisten
      parameters:
      - name: ordering
        required: false
        in: query
        description: Feld, das zum Sortieren der Ergebnisse verwendet werden soll.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: Eine Seitenzahl in der paginierten Ergebnismenge.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: Ein Suchbegriff.
        schema:
          type: string
      tags:
      - Admin
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedSystemSettingList'
          description: ''
    post:
      operationId: admin_settings_create
      description: CRUD for system settings (SuperAdmin only for write, Admin for
        read).
      summary: Systemeinstellung erstellen
      tags:
      - Admin
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SystemSettingRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/SystemSettingRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/SystemSettingRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SystemSetting'
          description: ''
  /api/v1/admin/settings/{id}/:
    get:
      operationId: admin_settings_retrieve
      description: CRUD for system settings (SuperAdmin only for write, Admin for
        read).
      summary: Systemeinstellung abrufen
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Admin
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SystemSetting'
          description: ''
    put:
      operationId: admin_settings_update
      description: CRUD for system settings (SuperAdmin only for write, Admin for
        read).
      summary: Systemeinstellung aktualisieren
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Admin
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SystemSettingRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/SystemSettingRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/SystemSettingRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SystemSetting'
          description: ''
    patch:
      operationId: admin_settings_partial_update
      description: CRUD for system settings (SuperAdmin only for write, Admin for
        read).
      summary: Systemeinstellung teilweise aktualisieren
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Admin
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedSystemSettingRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedSystemSettingRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedSystemSettingRequest'
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SystemSetting'
          description: ''
    delete:
      operationId: admin_settings_destroy
      description: CRUD for system settings (SuperAdmin only for write, Admin for
        read).
      summary: Systemeinstellung loeschen
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Admin
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '204':
          description: No response body
  /api/v1/auth/login/:
    post:
      operationId: auth_login_create
      description: Authentifizierung mit Benutzername/E-Mail und Passwort. Gibt JWT-Tokens
        zurück.
      summary: Benutzer anmelden
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/LoginRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/LoginRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/LoginRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      - {}
      responses:
        '200':
          description: Login erfolgreich
        '400':
          description: Ungültige Anmeldedaten
  /api/v1/auth/logout/:
    post:
      operationId: auth_logout_create
      description: Blacklistet den Refresh Token und meldet den Benutzer ab.
      summary: Benutzer abmelden
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/LogoutRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/LogoutRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/LogoutRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          description: Logout erfolgreich
        '400':
          description: Ungültiger Token
  /api/v1/auth/me/:
    get:
      operationId: auth_me_retrieve
      description: Gibt die Profildaten des angemeldeten Benutzers zurück.
      summary: Eigenes Profil abrufen
      tags:
      - Auth
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserProfile'
          description: ''
    patch:
      operationId: auth_me_partial_update
      description: Aktualisiert die Profildaten des angemeldeten Benutzers.
      summary: Eigenes Profil aktualisieren
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedUserProfileUpdateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedUserProfileUpdateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedUserProfileUpdateRequest'
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserProfile'
          description: ''
  /api/v1/auth/password-change/:
    post:
      operationId: auth_password_change_create
      description: Ändert das Passwort des angemeldeten Benutzers.
      summary: Passwort ändern
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PasswordChangeRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PasswordChangeRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PasswordChangeRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          description: Passwort erfolgreich geändert
        '400':
          description: Ungültiges Passwort
  /api/v1/auth/password-reset/:
    post:
      operationId: auth_password_reset_create
      description: Sendet eine E-Mail mit einem Link zum Zurücksetzen des Passworts.
      summary: Passwort-Reset anfordern
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PasswordResetRequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PasswordResetRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PasswordResetRequestRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      - {}
      responses:
        '200':
          description: E-Mail wurde gesendet (falls Konto existiert)
  /api/v1/auth/password-reset/confirm/:
    post:
      operationId: auth_password_reset_confirm_create
      description: Setzt das Passwort mit dem Token aus der E-Mail zurück.
      summary: Passwort-Reset bestätigen
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PasswordResetConfirmRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PasswordResetConfirmRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PasswordResetConfirmRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      - {}
      responses:
        '200':
          description: Passwort erfolgreich zurückgesetzt
        '400':
          description: Ungültiger Token oder Passwort
  /api/v1/auth/refresh/:
    post:
      operationId: auth_refresh_create
      description: Erneuert den Access Token mit einem gültigen Refresh Token.
      summary: Token erneuern
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/v1/export/leave-requests/:
    get:
      operationId: export_leave_requests_retrieve
      description: Exportiert Urlaubsanträge als CSV oder Excel-Datei.
      summary: Urlaubsanträge exportieren
      parameters:
      - in: query
        name: end_date
        schema:
          type: string
        description: Enddatum (YYYY-MM-DD)
      - in: query
        name: export_format
        schema:
          type: string
          enum:
          - csv
          - xlsx
          default: csv
        description: Export-Format
      - in: query
        name: start_date
        schema:
          type: string
        description: Startdatum (YYYY-MM-DD)
      - in: query
        name: status
        schema:
          type: string
        description: Status-Filter
      tags:
      - Export
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/export/time-entries/:
    get:
      operationId: export_time_entries_retrieve
      description: Exportiert Zeiteinträge als CSV oder Excel-Datei.
      summary: Zeiteinträge exportieren
      parameters:
      - in: query
        name: end_date
        schema:
          type: string
        description: Enddatum (YYYY-MM-DD)
      - in: query
        name: export_format
        schema:
          type: string
          enum:
          - csv
          - xlsx
          default: csv
        description: Export-Format
      - in: query
        name: group_id
        schema:
          type: integer
        description: Gruppen-Filter
      - in: query
        name: start_date
        schema:
          type: string
        description: Startdatum (YYYY-MM-DD)
      - in: query
        name: user_id
        schema:
          type: integer
        description: Benutzer-Filter
      tags:
      - Export
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/export/transactions/:
    get:
      operationId: export_transactions_retrieve
      description: Exportiert Transaktionen als CSV oder Excel-Datei.
      summary: Transaktionen exportieren
      parameters:
      - in: query
        name: end_date
        schema:
          type: string
        description: Enddatum (YYYY-MM-DD)
      - in: query
        name: export_format
        schema:
          type: string
          enum:
          - csv
          - xlsx
          default: csv
        description: Export-Format
      - in: query
        name: group_id
        schema:
          type: integer
        description: Gruppen-Filter
      - in: query
        name: start_date
        schema:
          type: string
        description: Startdatum (YYYY-MM-DD)
      - in: query
        name: status
        schema:
          type: string
        description: Status-Filter
      tags:
      - Export
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/finance/categories/:
    get:
      operationId: finance_categories_list
      description: |-
        CRUD for transaction categories.

        - Educators: read-only access to categories of their location
        - LocationManager+: full CRUD for their location's categories
      parameters:
      - in: query
        name: category_type
        schema:
          type: string
          title: Kategorie-Typ
          enum:
          - expense
          - income
        description: |-
          * `income` - Einnahme
          * `expense` - Ausgabe
      - in: query
        name: is_active
        schema:
          type: boolean
      - name: ordering
        required: false
        in: query
        description: Feld, das zum Sortieren der Ergebnisse verwendet werden soll.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: Eine Seitenzahl in der paginierten Ergebnismenge.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: Ein Suchbegriff.
        schema:
          type: string
      tags:
      - finance
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedTransactionCategoryListList'
          description: ''
    post:
      operationId: finance_categories_create
      description: |-
        CRUD for transaction categories.

        - Educators: read-only access to categories of their location
        - LocationManager+: full CRUD for their location's categories
      tags:
      - finance
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TransactionCategoryCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TransactionCategoryCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TransactionCategoryCreateRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TransactionCategoryCreate'
          description: ''
  /api/v1/finance/categories/{id}/:
    get:
      operationId: finance_categories_retrieve
      description: |-
        CRUD for transaction categories.

        - Educators: read-only access to categories of their location
        - LocationManager+: full CRUD for their location's categories
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: Ein eindeutiger Ganzzahl-Wert, der Transaktionskategorie identifiziert.
        required: true
      tags:
      - finance
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TransactionCategoryList'
          description: ''
    put:
      operationId: finance_categories_update
      description: |-
        CRUD for transaction categories.

        - Educators: read-only access to categories of their location
        - LocationManager+: full CRUD for their location's categories
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: Ein eindeutiger Ganzzahl-Wert, der Transaktionskategorie identifiziert.
        required: true
      tags:
      - finance
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TransactionCategoryCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TransactionCategoryCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TransactionCategoryCreateRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TransactionCategoryCreate'
          description: ''
    patch:
      operationId: finance_categories_partial_update
      description: |-
        CRUD for transaction categories.

        - Educators: read-only access to categories of their location
        - LocationManager+: full CRUD for their location's categories
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: Ein eindeutiger Ganzzahl-Wert, der Transaktionskategorie identifiziert.
        required: true
      tags:
      - finance
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedTransactionCategoryCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedTransactionCategoryCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedTransactionCategoryCreateRequest'
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TransactionCategoryCreate'
          description: ''
    delete:
      operationId: finance_categories_destroy
      description: |-
        CRUD for transaction categories.

        - Educators: read-only access to categories of their location
        - LocationManager+: full CRUD for their location's categories
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: Ein eindeutiger Ganzzahl-Wert, der Transaktionskategorie identifiziert.
        required: true
      tags:
      - finance
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '204':
          description: No response body
  /api/v1/finance/receipts/{id}/:
    get:
      operationId: finance_receipts_retrieve
      description: |-
        Standalone receipt operations (retrieve, delete).

        Receipts are primarily managed through the Transaction receipts action.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: Ein eindeutiger Ganzzahl-Wert, der Beleg identifiziert.
        required: true
      tags:
      - finance
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Receipt'
          description: ''
    delete:
      operationId: finance_receipts_destroy
      description: |-
        Standalone receipt operations (retrieve, delete).

        Receipts are primarily managed through the Transaction receipts action.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: Ein eindeutiger Ganzzahl-Wert, der Beleg identifiziert.
        required: true
      tags:
      - finance
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '204':
          description: No response body
  /api/v1/finance/transactions/:
    get:
      operationId: finance_transactions_list
      description: |-
        CRUD for financial transactions with approval workflow.

        - Educators: CRUD for own transactions in their groups
        - LocationManager+: approve/reject, view all in their location
        - Admin/SuperAdmin: full access
      parameters:
      - in: query
        name: category_id
        schema:
          type: number
      - in: query
        name: end_date
        schema:
          type: string
          format: date
      - in: query
        name: group_id
        schema:
          type: number
      - name: ordering
        required: false
        in: query
        description: Feld, das zum Sortieren der Ergebnisse verwendet werden soll.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: Eine Seitenzahl in der paginierten Ergebnismenge.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: Ein Suchbegriff.
        schema:
          type: string
      - in: query
        name: start_date
        schema:
          type: string
          format: date
      - in: query
        name: status
        schema:
          type: string
          enum:
          - approved
          - draft
          - pending
          - rejected
        description: |-
          * `draft` - Entwurf
          * `pending` - Ausstehend
          * `approved` - Genehmigt
          * `rejected` - Abgelehnt
      - in: query
        name: transaction_type
        schema:
          type: string
          title: Transaktionstyp
          enum:
          - expense
          - income
        description: |-
          * `income` - Einnahme
          * `expense` - Ausgabe
      tags:
      - finance
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedTransactionListList'
          description: ''
    post:
      operationId: finance_transactions_create
      description: |-
        CRUD for financial transactions with approval workflow.

        - Educators: CRUD for own transactions in their groups
        - LocationManager+: approve/reject, view all in their location
        - Admin/SuperAdmin: full access
      tags:
      - finance
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TransactionCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TransactionCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TransactionCreateRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
